# Backend admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# JWT secret used by backend
JWT_SECRET=please-change-me

# Key used to encrypt sensitive device string properties (32 bytes)
# Accepted formats:
# - 64 hex chars
# - base64 for 32 raw bytes
DEVICE_PROPERTIES_ENCRYPTION_KEY=a7ff4c72a483f6ea9ctbc39a0c6ddd3ece36g55a3d0f9cdb8c26a1d13c0378d3
# Comma-separated allowlist for browser origins allowed to call backend APIs
# Example: http://localhost:5173,https://dashboard.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://deviceportal.example.org

# Path to SQLite file inside the container
DB_PATH=/app/backend/data/data.db

# Path to SQLite directory on host (used for volume binding)
DB_PATH_HOST=./data
