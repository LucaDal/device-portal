# Backend admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# JWT secret used by backend
JWT_SECRET=please-change-me

# Key used to encrypt sensitive device string properties (32 bytes)
# Accepted formats:
# - 64 hex chars
# - base64 for 32 raw bytes
DEVICE_PROPERTIES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Comma-separated allowlist for browser origins allowed to call backend APIs
# Example: http://localhost:5173,https://dashboard.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Path to SQLite file inside the container
DB_PATH=/app/backend/data.db

# Path to SQLite file on host (used for volume binding)
DB_PATH_HOST=./backend/data.db
